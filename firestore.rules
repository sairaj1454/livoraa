rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin (role-based, no hardcoded emails)
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/customers/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/customers/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper function to validate employee data
    function isValidEmployee() {
      let employee = request.resource.data;
      return employee.name is string && employee.name.size() > 0 &&
             employee.email is string && employee.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             employee.phone is string && employee.phone.size() > 0 &&
             employee.position is string && employee.position.size() > 0 &&
             employee.salary is number && employee.salary >= 0 &&
             employee.status in ['active', 'inactive'];
    }

    // Helper function to validate project data
    function isValidProject() {
      let project = request.resource.data;
      return project.title is string && project.title.size() > 0 &&
             project.description is string &&
             project.client is string && project.client.size() > 0 &&
             project.clientEmail is string &&
             project.clientPhone is string &&
             project.location is string &&
             project.address.street is string &&
             project.address.city is string &&
             project.address.state is string &&
             project.address.pincode is string &&
             project.startDate is string;
    }

    // Helper function to validate quotation data
    function isValidQuotation() {
      let quotation = request.resource.data;
      return quotation.clientId is string &&
             quotation.clientName is string &&
             quotation.siteCode is string &&
             quotation.siteAddress is string &&
             quotation.version is string &&
             quotation.date is string &&
             quotation.items is list &&
             quotation.total is number &&
             quotation.timestamp is timestamp;
    }

    // Employee collection rules
    match /employees/{employeeId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidEmployee();
      allow update: if isAdmin() && isValidEmployee();
      allow delete: if isAdmin();
    }

    // Projects collection rules
    match /projects/{projectId} {
      allow read: if isAdmin() || (request.auth != null && 
               (request.auth.token.email == resource.data.clientEmail || 
                request.auth.token.email == resource.data.email));
      allow create: if isAdmin() && isValidProject();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admins collection rules
    match /admins/{adminId} {
      allow read: if isAdmin() || request.auth.uid == adminId;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Customers collection rules
    match /customers/{customerId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
      allow create: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
      allow delete: if isAdmin();
    }

    // Quotations collection rules
    match /quotations/{quotationId} {
      allow read: if isAdmin() || (request.auth != null && 
               resource.data.sentToClient == true &&
               (request.auth.token.email == resource.data.customerEmail || 
                request.auth.token.email == resource.data.clientEmail));
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Clients collection and quotations subcollection rules
    match /clients/{clientId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      
      match /quotations/{quotationId} {
        allow read: if isAdmin() || (request.auth != null && 
                 request.auth.token.email == resource.data.customerEmail);
        allow create: if isAdmin() && isValidQuotation();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // Gallery rules - only admin can write, anyone can read
    match /gallery/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Enquiries rules - anyone can create, only admin can read
    match /enquiries/{document} {
      allow create: if true;  // Allow public form submissions
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.email);
      allow update, delete: if isAdmin();  // Only admin can modify/delete
    }

    // Personalized Enquiries rules - anyone can create, only admin can read
    match /personalized_enquiries/{document} {
      allow create: if true;  // Allow public form submissions
      allow read: if isAdmin();
      allow update, delete: if isAdmin();  // Only admin can modify/delete
    }

    // Client Enquiries rules - authenticated customers can create/read their own, admin has full access
    match /client_enquiries/{document} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.email);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Blog rules - only admin can write, anyone can read
    match /blogs/{document} {
      allow read: if true;  // Allow public access to read blog posts
      allow create, update, delete: if isAdmin();  // Only admin can manage blogs
      
      // Blog validation
      allow create: if isAdmin()
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.content.size() > 0
        && request.resource.data.authorName.size() > 0
        && request.resource.data.category.size() > 0
        && request.resource.data.imageData.size() > 0;
    }

    // Testimonials rules - only admin can write, anyone can read
    match /testimonials/{document} {
      allow read: if true;  // Allow public access to read testimonials
      allow create, update, delete: if isAdmin();  // Only admin can manage testimonials
      
      // Testimonial validation
      allow create: if isAdmin()
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500
        && request.resource.data.date is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
    }

    // Receipts collection rules
    match /receipts/{receiptId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Saved Credentials collection rules (admin-only, for offline credential storage)
    match /savedCredentials/{credId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Business Details collection rules
    match /businessDetails/{businessId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Item Types collection rules
    match /itemTypes/{itemTypeId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings collection rules
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications collection rules
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.userEmail);
      allow create: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.userEmail);
      allow delete: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.userEmail);
    }

    // Function to validate image size
    function isValidImage() {
      let maxSize = 5 * 1024 * 1024;  // 5MB in bytes
      return request.resource.data.imageData.size() <= maxSize;
    }
  }
}
